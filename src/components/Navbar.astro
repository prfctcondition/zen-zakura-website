    <a href="#demo" class="text-sm text-[var(--color-text)] hover:opacity-70 transition-opacity duration-200 no-underline">demo</a>
    <a href="#pricing" class="text-sm text-[var(--color-text)] hover:opacity-70 transition-opacity duration-200 no-underline">pricing</a>
    <a href="/account" class="text-sm text-[var(--color-text)] hover:opacity-70 transition-opacity duration-200 no-underline">account</a>
  </div>
  <div class="flex items-center gap-3">
    <button id="theme-toggle" class="theme-icon w-8 h-8 rounded-[var(--radius-button)] flex items-center justify-center text-[var(--color-text)] hover:bg-[var(--glass-bg)] transition-all duration-200 cursor-pointer bg-transparent border border-[var(--color-text)]" aria-label="toggle theme">
      <svg class="light-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="1.3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="1.3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="dark-icon hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
