<section id="demo" class="relative py-12 md:py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="glass p-6 md:p-8 text-center mb-16 max-w-2xl mx-auto card-glow" data-tilt data-tilt-max="2" data-tilt-speed="270" data-tilt-glare="true" data-tilt-max-glare="0.03">
      <p class="text-xs text-[var(--color-text-secondary)] mb-2">demo</p>
      <h2 class="text-2xl md:text-4xl font-bold text-[var(--color-text)] mb-3 tracking-tight">
        see it in <span class="text-[var(--color-text-secondary)]">action</span>
      </h2>
      <p class="text-sm text-[var(--color-text-secondary)] max-w-md mx-auto">
        clean, intuitive interface designed for productivity.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <!-- Main window mockup -->
      <div class="md:col-span-2 glass p-4 md:p-6 overflow-hidden card-glow" data-tilt data-tilt-max="2" data-tilt-speed="270" data-tilt-glare="true" data-tilt-max-glare="0.03">
        <div class="relative rounded-[calc(var(--radius-panel)-4px)] overflow-hidden border border-[var(--color-text)]">
          <img src="/app_ui_light.webp" alt="zen zakura macro light ui" class="w-full block [html[data-theme='dark']_&]:hidden" />
          <img src="/app_ui_dark.webp" alt="zen zakura macro dark ui" class="w-full hidden [html[data-theme='dark']_&]:block" />
        </div>
      </div>

      <div class="glass p-5 md:p-6 card-glow" data-tilt data-tilt-max="2" data-tilt-speed="200" data-tilt-glare="true" data-tilt-max-glare="0.03">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-[var(--radius-button)] border border-[var(--color-text)] flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-[var(--color-text)]">one-click playback</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">assign hotkeys and launch instantly</p>
          </div>
        </div>
        <div class="h-1 w-full rounded-full bg-[var(--color-text)] opacity-10 overflow-hidden">
          <div class="h-full w-3/4 rounded-full bg-[var(--color-text)] opacity-40" />
        </div>
        <div class="flex justify-between mt-1 text-[10px] text-[var(--color-text-tertiary)]">
          <span>0ms</span>
          <span>250ms avg</span>
        </div>
      </div>

      <div class="glass p-5 md:p-6 card-glow" data-tilt data-tilt-max="2" data-tilt-speed="200" data-tilt-glare="true" data-tilt-max-glare="0.03">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-[var(--radius-button)] border border-[var(--color-text)] flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.67 1.5-1.5 0-.36-.14-.67-.33-.93-.19-.26-.33-.57-.33-.93 0-.83.67-1.5 1.5-1.5H16c3.86 0 7-3.14 7-7 0-5.52-4.48-10-11-10z"/></svg>
          </div>
          <div>
            <h3 class="text-base font-bold text-[var(--color-text)]">theme editor</h3>
            <p class="text-sm text-[var(--color-text-secondary)]">customize every color</p>
          </div>
        </div>
        <div class="flex gap-1.5">
          <div class="w-7 h-7 rounded-[var(--radius-button)] bg-[var(--color-text)] border-2 border-white/30" />
          <div class="w-7 h-7 rounded-[var(--radius-button)] bg-[var(--color-text)] opacity-60 border-2 border-white/30" />
          <div class="w-7 h-7 rounded-[var(--radius-button)] bg-[var(--color-text)] opacity-40 border-2 border-white/30" />
          <div class="w-7 h-7 rounded-[var(--radius-button)] bg-[var(--color-text)] opacity-30 border-2 border-white/30" />
          <div class="w-7 h-7 rounded-[var(--radius-button)] bg-[var(--color-text)] opacity-20 border-2 border-white/30" />
        </div>
      </div>
    </div>
  </div>
</section>
