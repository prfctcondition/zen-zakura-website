---
const features = [
  {
    title: "macro recording",
    desc: "record keyboard and mouse actions with precision. replay with a single hotkey.",
    icon: "record",
    span: "md:col-span-2 md:row-span-1",
  },
  {
    title: "snippet manager",
    desc: "store and insert text snippets instantly. perfect for repetitive typing tasks.",
    icon: "snippet",
    span: "md:col-span-1 md:row-span-1",
  },
  {
    title: "theme editor",
    desc: "customize every color with the built-in theme editor. create your perfect workspace.",
    icon: "palette",
    span: "md:col-span-1 md:row-span-2",
  },
  {
    title: "smart hotkeys",
    desc: "bind any action to any key combination. support for modifiers, mice, and more.",
    icon: "keyboard",
    span: "md:col-span-1 md:row-span-1",
  },
  {
    title: "lightning fast",
    desc: "c++ core engine ensures sub-millisecond playback. no delays, no overhead.",
    icon: "zap",
    span: "md:col-span-1 md:row-span-1",
  },
  {
    title: "cloud sync",
    desc: "your macros, snippets and themes synced across devices. pro feature.",
    icon: "cloud",
    pro: true,
    span: "md:col-span-1 md:row-span-1",
  },
];
---

<section id="features" class="relative py-24 md:py-32 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="glass p-6 md:p-8 text-center mb-16 max-w-2xl mx-auto">
      <p class="text-xs text-[var(--color-text)] opacity-70 mb-2">features</p>
      <h2 class="text-2xl md:text-4xl font-bold text-[var(--color-text)] mb-3 tracking-tight">
        crafted with <span class="opacity-70">precision</span>
      </h2>
      <p class="text-sm text-[var(--color-text-muted)] max-w-md mx-auto">
        every feature designed to make your workflow faster, smoother, and more elegant.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 auto-rows-[200px]">
      {features.map((f) => (
        <div
          class={`group glass p-5 md:p-6 overflow-hidden transition-all duration-300 ${f.span} ${f.pro ? "opacity-70 hover:opacity-100" : ""}`}
        >
          {f.pro && (
            <div class="mb-3 text-[10px] tracking-wider opacity-60">pro</div>
          )}

          <div class="flex items-start gap-3 h-full">
            <div class="shrink-0 w-9 h-9 rounded-[var(--radius-button)] border border-[var(--color-text)] flex items-center justify-center text-[var(--color-text)] group-hover:opacity-70 transition-opacity duration-300">
              {f.icon === "record" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
              )}
              {f.icon === "snippet" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              )}
              {f.icon === "palette" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.93 0 1.5-.67 1.5-1.5 0-.36-.14-.67-.33-.93-.19-.26-.33-.57-.33-.93 0-.83.67-1.5 1.5-1.5H16c3.86 0 7-3.14 7-7 0-5.52-4.48-10-11-10z"/></svg>
              )}
              {f.icon === "keyboard" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M6 16h.01M18 16h.01"/><path d="M10 16h4"/></svg>
              )}
              {f.icon === "zap" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              )}
              {f.icon === "cloud" && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
              )}
            </div>
            <div>
              <h3 class="text-base font-bold text-[var(--color-text)] mb-1">{f.title}</h3>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{f.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
