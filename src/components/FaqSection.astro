---
const faqs = [
  {
    q: "what is zen zakura macro?",
    a: "a professional macro automation tool for windows. record keyboard and mouse actions, create text snippets, customize themes, and automate repetitive tasks with japanese precision.",
  },
  {
    q: "is it free?",
    a: "yes! the free tier includes up to 3 macros and basic features. upgrade to pro ($5/month) for unlimited macros, snippets, theme editor, and cloud sync.",
  },
  {
    q: "how do i upgrade to pro?",
    a: "create an account in-app or on this website, then click upgrade to pro. you'll be redirected to stripe for secure payment.",
  },
  {
    q: "can i sync my macros across devices?",
    a: "yes, pro users get cloud sync. your macros, snippets, and themes are stored securely and synced across all your windows devices.",
  },
  {
    q: "is my data secure?",
    a: "absolutely. passwords are hashed with pbkdf2, sessions use jwt tokens, and all communication is encrypted via https.",
  },
];
---

<section id="faq" class="relative py-24 md:py-32 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <p class="text-xs text-[var(--color-text)] opacity-70 mb-3">faq</p>
      <h2 class="text-3xl md:text-5xl font-bold text-[var(--color-text)] mb-4 tracking-tight">
        any <span class="opacity-70">questions?</span>
      </h2>
    </div>

    <div class="space-y-2">
      {faqs.map((faq) => (
        <details class="group glass overflow-hidden transition-all duration-200 open:opacity-100">
          <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer list-none text-sm text-[var(--color-text)] hover:opacity-70 transition-opacity duration-200">
            {faq.q}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 transition-transform duration-200 group-open:rotate-180">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
