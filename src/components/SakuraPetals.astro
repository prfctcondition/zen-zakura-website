---
const petals = Array.from({ length: 25 }, () => ({
  left: `${Math.random() * 100}%`,
  size: `${14 + Math.random() * 16}px`,
  duration: `${12 + Math.random() * 14}s`,
  fallDelay: `-${Math.random() * 24}s`,
  swayDuration: `${3 + Math.random() * 4}s`,
  swayDelay: `-${Math.random() * 5}s`,
  rotateDuration: `${6 + Math.random() * 8}s`,
  rotateDelay: `-${Math.random() * 10}s`,
}));
---

{petals.map((p) => (
  <svg
    class="petal"
    viewBox="0 0 30 40"
    style={`
      left: ${p.left};
      width: ${p.size};
      height: ${p.size};
      animation-duration: ${p.duration}, ${p.swayDuration}, ${p.rotateDuration};
      animation-delay: ${p.fallDelay}, ${p.swayDelay}, ${p.rotateDelay};
    `}
  >
    <path d="M15 2 C22 8 28 18 26 26 C24 34 18 38 15 38 C12 38 6 34 4 26 C2 18 8 8 15 2Z" />
  </svg>
))}
