---
const petals = Array.from({ length: 30 }, () => ({
  left: `${Math.random() * 100}%`,
  size: `${14 + Math.random() * 16}px`,
  duration: `${12 + Math.random() * 14}s`,
  fallDelay: `-${Math.random() * 24}s`,
  windDuration: `${8 + Math.random() * 10}s`,
  windDelay: `-${Math.random() * 15}s`,
  rotateDuration: `${6 + Math.random() * 8}s`,
  rotateDelay: `-${Math.random() * 10}s`,
}));
---

{petals.map((p) => (
  <div
    class="petal"
    style={`
      left: ${p.left};
      width: ${p.size};
      height: ${p.size};
      animation-duration: ${p.duration}, ${p.windDuration}, ${p.rotateDuration};
      animation-delay: ${p.fallDelay}, ${p.windDelay}, ${p.rotateDelay};
    `}
  />
))}
