---
const petals = Array.from({ length: 25 }, () => ({
  left: `${Math.random() * 100}%`,
  size: `${14 + Math.random() * 16}px`,
  duration: `${12 + Math.random() * 14}s`,
  fallDelay: `-${Math.random() * 22}s`,
  swayDuration: `${3 + Math.random() * 4}s`,
  swayDelay: `-${Math.random() * 5}s`,
}));
---

{petals.map((p) => (
  <div
    class="petal"
    style={`
      left: ${p.left};
      width: ${p.size};
      height: ${p.size};
      animation-duration: ${p.duration}, ${p.swayDuration};
      animation-delay: ${p.fallDelay}, ${p.swayDelay};
    `}
  />
))}
