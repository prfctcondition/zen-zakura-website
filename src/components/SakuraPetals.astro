---
const petals = Array.from({ length: 44 }, (_, i) => {
  const fromLeft = i < 25;
  const duration = 12 + Math.random() * 14;
  return {
    left: fromLeft
      ? `${Math.random() * 30}%`
      : `${Math.random() * 95}%`,
    size: `${21 + Math.random() * 24}px`,
    duration: `${duration}s`,
    fallDelay: `-${Math.random() * 24}s`,
    windDuration: fromLeft
      ? `${7 + Math.random() * 8}s`
      : `${12 + Math.random() * 10}s`,
    windDelay: `-${Math.random() * 15}s`,
    rotateDuration: `${6 + Math.random() * 8}s`,
    rotateDelay: `-${Math.random() * 10}s`,
  };
});
---

{petals.map((p) => (
  <div
    class="petal"
    style={`
      left: ${p.left};
      width: ${p.size};
      height: ${p.size};
      animation-duration: ${p.duration}, ${p.windDuration}, ${p.rotateDuration}, ${p.duration};
      animation-delay: ${p.fallDelay}, ${p.windDelay}, ${p.rotateDelay}, ${p.fallDelay};
    `}
  />
))}
