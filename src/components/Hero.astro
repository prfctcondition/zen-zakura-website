<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20">
  <div class="relative z-10 w-full max-w-4xl mx-auto px-4 flex flex-col items-center">
    <!-- Logo floating above glass panel, no glass bg -->
    <div class="flex justify-center mb-6">
      <img src="/logo_light.webp" alt="zen zakura macro" class="w-auto max-w-[300px] sm:max-w-[400px] md:max-w-[500px] block [html[data-theme='dark']_&]:hidden" />
      <img src="/logo_dark.webp" alt="zen zakura macro" class="w-auto max-w-[300px] sm:max-w-[400px] md:max-w-[500px] hidden [html[data-theme='dark']_&]:block" />
    </div>

    <!-- Small glass panel below -->
    <div class="glass px-6 py-5 md:px-8 md:py-6 text-center card-glow max-w-lg w-full" data-tilt data-tilt-max="2" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.05">
      <p class="text-sm md:text-base text-[var(--color-text-secondary)] leading-relaxed mb-5">
        professional macro automation tool with elegant design.
        record, edit, and automate with japanese precision.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#download" class="btn-primary no-underline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          download free
        </a>
        <a href="#pricing" class="inline-flex items-center gap-2 px-5 py-2 rounded-[var(--radius-button)] border border-[var(--color-text)] text-[var(--color-text)] text-sm font-medium hover:bg-[var(--glass-bg)] transition-all duration-200 no-underline cursor-pointer">
          upgrade to pro
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center gap-2 text-[var(--color-text)] animate-bounce">
      <span class="text-xs">scroll</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </div>
  </div>
</section>
