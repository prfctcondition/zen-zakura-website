<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import Lenis from "lenis";
import VanillaTilt from "vanilla-tilt";

gsap.registerPlugin(ScrollTrigger);

function initAnimations() {
  var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── Prevent scroll restoration on reload ──
  if (history.scrollRestoration) {
    history.scrollRestoration = "manual";
  }
  window.scrollTo(0, 0);

  // ── General animation config ──
  var defaults = {
    ease: "power3.out",
    duration: 0.6,
  };

  function fadeUp(el, opts) {
    gsap.from(el, {
      y: opts.y || 30,
      opacity: 0,
      duration: opts.duration || 0.6,
      ease: "power3.out",
      stagger: opts.stagger || 0,
      immediateRender: false,
      scrollTrigger: {
        trigger: opts.trigger || el,
        start: opts.start || "top 88%",
        toggleActions: "play none none none",
        once: true,
      },
    });
  }

  // ── Hero title ──
  fadeUp("#hero-title", { y: 20, duration: 0.5, start: "top 80%" });

  // ── Feature cards stagger ──
  fadeUp("#features .group", { trigger: "#features .grid", stagger: 0.08 });

  // ── Section headers ──
  gsap.utils.toArray("section > div > .text-center").forEach(function(header) {
    fadeUp(header, { y: 20, duration: 0.5 });
  });

  // ── Demo cards ──
  fadeUp("#demo .grid > .glass", { trigger: "#demo .grid", stagger: 0.1 });

  // ── Pricing cards ──
  fadeUp("#pricing .grid > .glass, #pricing .grid > .glass-strong", {
    trigger: "#pricing .grid",
    stagger: 0.15,
    start: "top 85%",
  });

  // ── FAQ items ──
  fadeUp("#faq details", { trigger: "#faq .space-y-2", stagger: 0.05, y: 10, duration: 0.4 });

  // ── CTA ──
  fadeUp("#download .glass", { trigger: "#download", start: "top 85%", y: 0 });

  // ── Vanilla-tilt ──
  if (!prefersReduced) {
    try {
      VanillaTilt.init(document.querySelectorAll("[data-tilt]"), {});
    } catch(e) {}
  }

  // ── Lenis smooth scroll ──
  if (!prefersReduced) {
    var lenis = new Lenis({
      duration: 1.2,
      easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)) },
      smoothWheel: true,
    });
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add(function(time) { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);
  }

  // ── Refresh ScrollTrigger after everything is set up ──
  requestAnimationFrame(function() { ScrollTrigger.refresh(); });
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initAnimations);
} else {
  initAnimations();
}
</script>
