<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import Lenis from "lenis";
import VanillaTilt from "vanilla-tilt";

gsap.registerPlugin(ScrollTrigger);

function initAnimations() {
  var prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function slideUp(el, opts) {
    gsap.from(el, {
      y: opts.y || 24,
      duration: opts.duration || 0.5,
      ease: "power3.out",
      stagger: opts.stagger || 0,
      scrollTrigger: {
        trigger: opts.trigger || el,
        start: opts.start || "top 88%",
        toggleActions: "play none none none",
        once: true,
      },
    });
  }

  // ── Hero title ──
  slideUp("#hero-title", { y: 16, duration: 0.4, start: "top 80%" });

  // ── Feature cards stagger ──
  slideUp("#features .group", { trigger: "#features .grid", stagger: 0.06 });

  // ── Section headers ──
  gsap.utils.toArray("section > div > .text-center").forEach(function(header) {
    slideUp(header, { y: 16, duration: 0.4 });
  });

  // ── Demo cards ──
  slideUp("#demo .grid > .glass", { trigger: "#demo .grid", stagger: 0.08 });

  // ── Pricing cards ──
  slideUp("#pricing .grid > .glass, #pricing .grid > .glass-strong", {
    trigger: "#pricing .grid",
    stagger: 0.1,
    start: "top 85%",
  });

  // ── FAQ items ──
  slideUp("#faq details", { trigger: "#faq .space-y-2", stagger: 0.04, y: 12, duration: 0.35 });

  // ── CTA ──
  slideUp("#download .glass", { trigger: "#download", start: "top 85%", y: 0 });

  // ── Vanilla-tilt ──
  if (!prefersReduced) {
    try { VanillaTilt.init(document.querySelectorAll("[data-tilt]"), {}); } catch(e) {}
  }

  // ── Lenis smooth scroll ──
  if (!prefersReduced) {
    var lenis = new Lenis({
      duration: 1.2,
      easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)) },
      smoothWheel: true,
    });
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add(function(time) { lenis.raf(time * 1000); });
    gsap.ticker.lagSmoothing(0);
  }

  requestAnimationFrame(function() { ScrollTrigger.refresh(); });
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initAnimations);
} else {
  initAnimations();
}
</script>
