---
// GSAP scroll animations + Lenis + Splitting text reveal
---

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";
import Lenis from "lenis";
import VanillaTilt from "vanilla-tilt";

gsap.registerPlugin(ScrollTrigger);

function initAnimations() {
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ── Lenis smooth scroll ──
  if (!prefersReduced) {
    const lenis = new Lenis({
      duration: 1.2,
      easing: function(t) { return Math.min(1, 1.001 - Math.pow(2, -10 * t)) },
      orientation: 'vertical',
      smoothWheel: true,
    });

    lenis.on('scroll', ScrollTrigger.update);

    gsap.ticker.add(function(time) {
      lenis.raf(time * 1000);
    });

    gsap.ticker.lagSmoothing(0);
  }

  // ── Feature cards stagger ──
  gsap.from("#features .group", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.08,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#features .grid",
      start: "top 85%",
    },
  });

  // ── Section headers blanket fade ──
  gsap.utils.toArray("section > div > .text-center").forEach(function(header) {
    gsap.from(header, {
      y: 20,
      opacity: 0,
      duration: 0.5,
      ease: "power3.out",
      scrollTrigger: {
        trigger: header,
        start: "top 85%",
      },
    });
  });

  // ── Demo cards ──
  gsap.from("#demo .grid > .glass", {
    y: 30,
    opacity: 0,
    duration: 0.5,
    stagger: 0.1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#demo .grid",
      start: "top 85%",
    },
  });

  // ── Pricing cards ──
  gsap.from("#pricing .grid > .glass, #pricing .grid > .glass-strong", {
    y: 20,
    opacity: 0,
    duration: 0.5,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#pricing .grid",
      start: "top 85%",
    },
  });

  // ── FAQ items ──
  gsap.from("#faq details", {
    y: 10,
    opacity: 0,
    duration: 0.4,
    stagger: 0.05,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#faq .space-y-2",
      start: "top 85%",
    },
  });

  // ── CTA ──
  gsap.from("#download .glass", {
    scale: 0.97,
    opacity: 0,
    duration: 0.6,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#download",
      start: "top 80%",
    },
  });

  // ── Init vanilla-tilt on tilt-enabled elements ──
  if (!prefersReduced) {
    VanillaTilt.init(document.querySelectorAll('[data-tilt]'), {});
  }

  ScrollTrigger.refresh();
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initAnimations);
} else {
  initAnimations();
}
</script>
