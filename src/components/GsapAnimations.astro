---
// GSAP scroll animations
---

<script>
import { gsap } from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

function initAnimations() {
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (prefersReduced) return;

  // Feature cards stagger
  gsap.from("#features .group", {
    y: 30,
    opacity: 0,
    duration: 0.6,
    stagger: 0.08,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#features .grid",
      start: "top 85%",
    },
  });

  // Section headers
  gsap.utils.toArray("section > div > .text-center").forEach((header) => {
    gsap.from(header, {
      y: 20,
      opacity: 0,
      duration: 0.5,
      ease: "power3.out",
      scrollTrigger: {
        trigger: header,
        start: "top 85%",
      },
    });
  });

  // Demo mockups
  gsap.from("#demo .glass", {
    y: 30,
    opacity: 0,
    duration: 0.5,
    stagger: 0.1,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#demo .grid",
      start: "top 85%",
    },
  });

  // Pricing cards
  gsap.from("#pricing .glass, #pricing .glass-strong", {
    y: 20,
    opacity: 0,
    duration: 0.5,
    stagger: 0.15,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#pricing .grid",
      start: "top 85%",
    },
  });

  // FAQ items
  gsap.from("#faq details", {
    y: 10,
    opacity: 0,
    duration: 0.4,
    stagger: 0.05,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#faq .space-y-2",
      start: "top 85%",
    },
  });

  // CTA section
  gsap.from("#download .max-w-2xl", {
    scale: 0.97,
    opacity: 0,
    duration: 0.6,
    ease: "power3.out",
    scrollTrigger: {
      trigger: "#download",
      start: "top 80%",
    },
  });

  ScrollTrigger.refresh();
}

if (document.readyState === "loading") {
  document.addEventListener("DOMContentLoaded", initAnimations);
} else {
  initAnimations();
}
</script>
