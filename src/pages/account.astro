---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Account — zen zakura マクロ">
  <main class="min-h-screen flex items-center justify-center px-4 py-20">
    <!-- Decorative blobs -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-sakura/5 blur-3xl" />
      <div class="absolute -bottom-40 -left-40 w-80 h-80 rounded-full bg-sakura-light/5 blur-3xl" />
    </div>

    <div class="relative z-10 w-full max-w-md" id="account-app">
      <!-- Loading state -->
      <div id="loading-state" class="glass rounded-2xl p-8 text-center">
        <div class="animate-spin w-6 h-6 border-2 border-sakura border-t-transparent rounded-full mx-auto mb-4" />
        <p class="text-sm text-ink/50">Loading...</p>
      </div>

      <!-- Login form (shown by default) -->
      <div id="login-form" class="glass rounded-2xl p-8 hidden">
        <div class="text-center mb-8">
          <h1 class="font-serif-jp text-2xl font-bold text-ink mb-1">
            zen zakura <span class="text-sakura">マクロ</span>
          </h1>
          <p class="text-sm text-ink/50">Sign in to your account</p>
        </div>

        <form id="auth-form" class="space-y-4">
          <div>
            <label for="email" class="block text-xs font-medium text-ink/60 mb-1.5">Email</label>
            <input
              id="email"
              type="email"
              required
              placeholder="you@example.com"
              class="w-full px-4 py-2.5 rounded-xl border border-sakura/20 bg-white/50 text-ink text-sm placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-sakura/30 focus:border-sakura/50 transition-all duration-200"
            />
          </div>
          <div>
            <label for="password" class="block text-xs font-medium text-ink/60 mb-1.5">Password</label>
            <input
              id="password"
              type="password"
              required
              placeholder="••••••••"
              class="w-full px-4 py-2.5 rounded-xl border border-sakura/20 bg-white/50 text-ink text-sm placeholder:text-ink/30 focus:outline-none focus:ring-2 focus:ring-sakura/30 focus:border-sakura/50 transition-all duration-200"
            />
          </div>

          <div id="error-message" class="text-xs text-crimson hidden"></div>

          <button
            type="submit"
            class="w-full py-2.5 rounded-xl bg-ink text-white text-sm font-medium hover:bg-ink/90 transition-all duration-200 cursor-pointer"
          >
            Sign In
          </button>
        </form>

        <div class="mt-4 text-center">
          <button
            id="toggle-auth-mode"
            class="text-xs text-sakura hover:text-sakura/80 transition-colors cursor-pointer bg-transparent border-none"
          >
            Don't have an account? Register
          </button>
        </div>
      </div>

      <!-- Dashboard (shown after login) -->
      <div id="dashboard" class="glass rounded-2xl p-8 hidden">
        <div class="text-center mb-6">
          <div class="w-16 h-16 rounded-full bg-sakura/10 mx-auto mb-3 flex items-center justify-center">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sakura">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <h2 class="font-serif-jp text-xl font-bold text-ink" id="dashboard-email">user@example.com</h2>
          <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-semibold mt-1 tracking-wider" id="dashboard-tier-badge">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Free
          </div>
        </div>

        <div class="space-y-3">
          <a href="#" id="upgrade-btn" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl bg-crimson text-white text-sm font-medium hover:bg-crimson/90 transition-all duration-200 no-underline cursor-pointer shadow-lg shadow-crimson/10">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Upgrade to Pro
          </a>
          <a href="#" id="manage-billing-btn" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-xl border border-sakura/20 text-ink text-sm font-medium hover:bg-sakura/5 transition-all duration-200 no-underline cursor-pointer">
            Manage Billing
          </a>
          <button id="logout-btn" class="w-full py-2.5 rounded-xl text-sm text-ink/40 hover:text-crimson hover:bg-crimson/5 transition-all duration-200 cursor-pointer bg-transparent border-none">
            Log Out
          </button>
        </div>
      </div>
    </div>
  </main>

  <script>
    const API_BASE = "https://zen-zakura-api.zen-zakura.workers.dev";

    // State
    let isRegisterMode = false;
    let authToken = localStorage.getItem("zz_token");

    // DOM refs
    const loginForm = document.getElementById("login-form");
    const dashboard = document.getElementById("dashboard");
    const loadingState = document.getElementById("loading-state");
    const authForm = document.getElementById("auth-form");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const errorMsg = document.getElementById("error-message");
    const toggleBtn = document.getElementById("toggle-auth-mode");
    const dashboardEmail = document.getElementById("dashboard-email");
    const tierBadge = document.getElementById("dashboard-tier-badge");
    const upgradeBtn = document.getElementById("upgrade-btn");
    const manageBillingBtn = document.getElementById("manage-billing-btn");
    const logoutBtn = document.getElementById("logout-btn");

    // Auto-login check
    async function checkAuth() {
      if (!authToken) {
        loadingState.classList.add("hidden");
        loginForm.classList.remove("hidden");
        return;
      }

      try {
        const res = await fetch(`${API_BASE}/verify`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token: authToken }),
        });

        if (res.ok) {
          const data = await res.json();
          const isPro = data.sub_status === "pro" || data.sub_status === "active";
          showDashboard(data.email, isPro);
        } else {
          localStorage.removeItem("zz_token");
          authToken = null;
          loadingState.classList.add("hidden");
          loginForm.classList.remove("hidden");
        }
      } catch (e) {
        // API not reachable — show login anyway
        loadingState.classList.add("hidden");
        loginForm.classList.remove("hidden");
      }
    }

    function showDashboard(email, isPro) {
      loadingState.classList.add("hidden");
      dashboard.classList.remove("hidden");

      dashboardEmail.textContent = email;

      if (isPro) {
        tierBadge.className = "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-semibold tracking-wider bg-gold/10 text-gold";
        tierBadge.innerHTML = `<svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg> Pro`;
        upgradeBtn.classList.add("hidden");
      } else {
        tierBadge.className = "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-[10px] font-semibold tracking-wider bg-sakura/10 text-sakura";
        tierBadge.innerHTML = `Free`;
        upgradeBtn.classList.remove("hidden");
      }
    }

    // Login / Register
    authForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorMsg.classList.add("hidden");

      const email = emailInput.value.trim();
      const password = passwordInput.value;
      const endpoint = isRegisterMode ? "/register" : "/login";

      try {
        const res = await fetch(`${API_BASE}${endpoint}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          errorMsg.textContent = data.error || "Something went wrong";
          errorMsg.classList.remove("hidden");
          return;
        }

        // Save token
        localStorage.setItem("zz_token", data.token);
        authToken = data.token;

        // Show dashboard
        loginForm.classList.add("hidden");
        const isPro = data.sub_status === "pro" || data.sub_status === "active";
        showDashboard(email, isPro);
      } catch (e) {
        errorMsg.textContent = "Cannot connect to server. Try again later.";
        errorMsg.classList.remove("hidden");
      }
    });

    // Toggle login/register mode
    toggleBtn.addEventListener("click", () => {
      isRegisterMode = !isRegisterMode;
      const btn = authForm.querySelector('button[type="submit"]');
      btn.textContent = isRegisterMode ? "Register" : "Sign In";
      toggleBtn.textContent = isRegisterMode
        ? "Already have an account? Sign In"
        : "Don't have an account? Register";
      errorMsg.classList.add("hidden");
    });

    // Upgrade to Pro
    upgradeBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(`${API_BASE}/create-checkout-session`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${authToken}`,
          },
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        }
      } catch (e) {
        errorMsg.textContent = "Cannot connect to payment server.";
        errorMsg.classList.remove("hidden");
      }
    });

    // Manage Billing
    manageBillingBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(`${API_BASE}/create-portal-session`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${authToken}`,
          },
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        }
      } catch (e) {
        errorMsg.textContent = "Cannot connect to billing portal.";
        errorMsg.classList.remove("hidden");
      }
    });

    // Logout
    logoutBtn.addEventListener("click", () => {
      localStorage.removeItem("zz_token");
      authToken = null;
      dashboard.classList.add("hidden");
      loginForm.classList.remove("hidden");
    });

    // Init
    checkAuth();
  </script>
</BaseLayout>
