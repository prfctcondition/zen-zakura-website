---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="account — zen zakura マクロ">
  <main class="min-h-screen flex items-center justify-center px-4 py-20">
    <div class="relative z-10 w-full max-w-md" id="account-app">
      <!-- Loading state -->
      <div id="loading-state" class="glass p-8 text-center">
        <div class="animate-spin w-5 h-5 border border-[var(--color-text)] border-t-transparent rounded-full mx-auto mb-3" />
        <p class="text-sm text-[var(--color-text-muted)]">loading...</p>
      </div>

      <!-- Login form -->
      <div id="login-form" class="glass p-8 hidden">
        <div class="text-center mb-8">
          <h1 class="text-xl font-bold text-[var(--color-text)] mb-1">
            zen zakura <span class="opacity-70">マクロ</span>
          </h1>
          <p class="text-sm text-[var(--color-text-muted)]">sign in to your account</p>
        </div>

        <form id="auth-form" class="space-y-4">
          <div>
            <label for="email" class="block text-xs text-[var(--color-text-muted)] mb-1.5">email</label>
            <input
              id="email"
              type="email"
              required
              placeholder="you@example.com"
              class="w-full px-4 py-2.5 rounded-[var(--radius-button)] bg-[var(--input-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-dim)] focus:outline-none focus:ring-1 focus:ring-[var(--color-text)] transition-all duration-200 border border-[var(--color-text)]"
            />
          </div>
          <div>
            <label for="password" class="block text-xs text-[var(--color-text-muted)] mb-1.5">password</label>
            <input
              id="password"
              type="password"
              required
              placeholder="••••••••"
              class="w-full px-4 py-2.5 rounded-[var(--radius-button)] bg-[var(--input-bg)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-dim)] focus:outline-none focus:ring-1 focus:ring-[var(--color-text)] transition-all duration-200 border border-[var(--color-text)]"
            />
          </div>

          <div id="error-message" class="text-xs text-[var(--color-text)] hidden"></div>

          <button
            type="submit"
            class="w-full py-2.5 rounded-[var(--radius-button)] bg-[var(--color-text)] text-white text-sm font-medium hover:opacity-80 transition-all duration-200 cursor-pointer"
          >
            sign in
          </button>
        </form>

        <div class="mt-4 text-center">
          <button
            id="toggle-auth-mode"
            class="text-xs text-[var(--color-text)] hover:opacity-70 transition-opacity cursor-pointer bg-transparent border-none"
          >
            don't have an account? register
          </button>
        </div>
      </div>

      <!-- Dashboard -->
      <div id="dashboard" class="glass p-8 hidden">
        <div class="text-center mb-6">
          <div class="w-14 h-14 rounded-full border border-[var(--color-text)] mx-auto mb-3 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="opacity-70">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold text-[var(--color-text)]" id="dashboard-email">user@example.com</h2>
          <div class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-[var(--radius-button)] text-[10px] mt-1 border border-[var(--color-text)]" id="dashboard-tier-badge">
            free
          </div>
        </div>

        <div class="space-y-3">
          <a href="#" id="upgrade-btn" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-[var(--radius-button)] bg-[var(--color-text)] text-white text-sm font-medium hover:opacity-80 transition-all duration-200 no-underline cursor-pointer">
            upgrade to pro
          </a>
          <a href="#" id="manage-billing-btn" class="w-full flex items-center justify-center gap-2 py-2.5 rounded-[var(--radius-button)] border border-[var(--color-text)] text-[var(--color-text)] text-sm font-medium hover:bg-[var(--glass-bg)] transition-all duration-200 no-underline cursor-pointer">
            manage billing
          </a>
          <button id="logout-btn" class="w-full py-2.5 rounded-[var(--radius-button)] text-sm text-[var(--color-text-muted)] hover:opacity-60 hover:bg-red-500/5 transition-all duration-200 cursor-pointer bg-transparent border border-[var(--color-text)] opacity-50">
            log out
          </button>
        </div>
      </div>
    </div>
  </main>

  <script>
    const API_BASE = "https://zen-zakura-api.zen-zakura.workers.dev";

    let isRegisterMode = false;
    let authToken = localStorage.getItem("zz_token");

    const loginForm = document.getElementById("login-form");
    const dashboard = document.getElementById("dashboard");
    const loadingState = document.getElementById("loading-state");
    const authForm = document.getElementById("auth-form");
    const emailInput = document.getElementById("email");
    const passwordInput = document.getElementById("password");
    const errorMsg = document.getElementById("error-message");
    const toggleBtn = document.getElementById("toggle-auth-mode");
    const dashboardEmail = document.getElementById("dashboard-email");
    const tierBadge = document.getElementById("dashboard-tier-badge");
    const upgradeBtn = document.getElementById("upgrade-btn");
    const manageBillingBtn = document.getElementById("manage-billing-btn");
    const logoutBtn = document.getElementById("logout-btn");

    async function checkAuth() {
      if (!authToken) {
        loadingState.classList.add("hidden");
        loginForm.classList.remove("hidden");
        return;
      }

      try {
        const res = await fetch(`${API_BASE}/verify`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ token: authToken }),
        });

        if (res.ok) {
          const data = await res.json();
          const isPro = data.sub_status === "pro" || data.sub_status === "active";
          showDashboard(data.email, isPro);
        } else {
          localStorage.removeItem("zz_token");
          authToken = null;
          loadingState.classList.add("hidden");
          loginForm.classList.remove("hidden");
        }
      } catch (e) {
        loadingState.classList.add("hidden");
        loginForm.classList.remove("hidden");
      }
    }

    function showDashboard(email, isPro) {
      loadingState.classList.add("hidden");
      dashboard.classList.remove("hidden");

      dashboardEmail.textContent = email;

      if (isPro) {
        tierBadge.innerHTML = `pro`;
        upgradeBtn.classList.add("hidden");
      } else {
        tierBadge.innerHTML = `free`;
        upgradeBtn.classList.remove("hidden");
      }
    }

    authForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorMsg.classList.add("hidden");

      const email = emailInput.value.trim();
      const password = passwordInput.value;
      const endpoint = isRegisterMode ? "/register" : "/login";

      try {
        const res = await fetch(`${API_BASE}${endpoint}`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password }),
        });

        const data = await res.json();

        if (!res.ok) {
          errorMsg.textContent = data.error || "something went wrong";
          errorMsg.classList.remove("hidden");
          return;
        }

        localStorage.setItem("zz_token", data.token);
        authToken = data.token;

        loginForm.classList.add("hidden");
        const isPro = data.sub_status === "pro" || data.sub_status === "active";
        showDashboard(email, isPro);
      } catch (e) {
        errorMsg.textContent = "cannot connect to server. try again later.";
        errorMsg.classList.remove("hidden");
      }
    });

    toggleBtn.addEventListener("click", () => {
      isRegisterMode = !isRegisterMode;
      const btn = authForm.querySelector('button[type="submit"]');
      btn.textContent = isRegisterMode ? "register" : "sign in";
      toggleBtn.textContent = isRegisterMode
        ? "already have an account? sign in"
        : "don't have an account? register";
      errorMsg.classList.add("hidden");
    });

    upgradeBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(`${API_BASE}/create-checkout-session`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${authToken}`,
          },
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        }
      } catch (e) {
        errorMsg.textContent = "cannot connect to payment server.";
        errorMsg.classList.remove("hidden");
      }
    });

    manageBillingBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      try {
        const res = await fetch(`${API_BASE}/create-portal-session`, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: `Bearer ${authToken}`,
          },
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        }
      } catch (e) {
        errorMsg.textContent = "cannot connect to billing portal.";
        errorMsg.classList.remove("hidden");
      }
    });

    logoutBtn.addEventListener("click", () => {
      localStorage.removeItem("zz_token");
      authToken = null;
      dashboard.classList.add("hidden");
      loginForm.classList.remove("hidden");
    });

    checkAuth();
  </script>
</BaseLayout>
