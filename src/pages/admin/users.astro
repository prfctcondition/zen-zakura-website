---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import SakuraPetals from "@/components/SakuraPetals.astro";
---

<BaseLayout title="admin users — zen zakura マクロ">
  <SakuraPetals />
  <Navbar />
  <main class="min-h-screen px-4 py-32 max-w-6xl mx-auto" id="admin-users-app">
    <div id="admin-loading" class="glass p-10 text-center">
      <div class="animate-spin w-5 h-5 border border-[var(--color-text)] border-t-transparent rounded-full mx-auto mb-3" />
      <p class="text-sm text-[var(--color-text-secondary)]">loading...</p>
    </div>
    <div id="admin-content" class="hidden">
      <div class="glass p-6 md:p-8 mb-6 text-center">
        <h1 class="text-xl md:text-2xl font-bold text-[var(--color-text)] mb-1">user management</h1>
      </div>
      <nav class="flex gap-2 mb-6">
        <a href="/admin" class="px-4 py-2 rounded-[var(--radius-button)] text-sm font-medium border border-[var(--color-text)] text-[var(--color-text)] no-underline hover:bg-[var(--glass-bg)] transition-all">dashboard</a>
        <a href="/admin/users" class="px-4 py-2 rounded-[var(--radius-button)] text-sm font-medium border border-[var(--color-text)] text-[var(--color-text)] no-underline bg-[var(--color-text)] text-white">users</a>
      </nav>
      <div class="glass p-6 card-glow mb-6">
        <div class="flex gap-2 mb-4">
          <input id="search-input" type="text" placeholder="search by email or username" class="flex-1 px-3 py-2 rounded-[var(--radius-button)] bg-[var(--input-bg)] text-[var(--color-text)] text-sm border border-[var(--color-text)] focus:outline-none focus:ring-1 focus:ring-[var(--color-text)]" />
          <button id="search-btn" class="px-4 py-2 rounded-[var(--radius-button)] text-sm border border-[var(--color-text)] text-[var(--color-text)] hover:bg-[var(--glass-bg)] transition-all cursor-pointer bg-transparent">search</button>
        </div>
        <div id="users-table" class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead><tr class="text-[var(--color-text-secondary)] text-xs text-left">
              <th class="pb-2 pr-2">id</th>
              <th class="pb-2 pr-2">email</th>
              <th class="pb-2 pr-2">username</th>
              <th class="pb-2 pr-2">status</th>
              <th class="pb-2 pr-2">expires</th>
              <th class="pb-2 pr-2">actions</th>
            </tr></thead>
            <tbody id="users-body"></tbody>
          </table>
        </div>
        <div id="users-pagination" class="flex gap-2 mt-4 justify-center"></div>
        <p id="users-empty" class="text-xs text-[var(--color-text-secondary)] mt-4 text-center hidden">no users found</p>
      </div>
    </div>

    <!-- Edit modal -->
    <div id="edit-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/20 backdrop-blur-sm">
      <div class="glass p-6 max-w-sm w-full mx-4">
        <h3 class="text-sm font-bold text-[var(--color-text)] mb-4">edit user #<span id="edit-id"></span></h3>
        <div class="space-y-3">
          <div>
            <label class="block text-xs text-[var(--color-text-secondary)] mb-1">subscription status</label>
            <select id="edit-status" class="w-full px-3 py-2 rounded-[var(--radius-button)] bg-[var(--input-bg)] text-[var(--color-text)] text-sm border border-[var(--color-text)]">
              <option value="free">free</option>
              <option value="active">pro (active)</option>
              <option value="expired">expired</option>
              <option value="dev">dev</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-[var(--color-text-secondary)] mb-1">expiry date (optional)</label>
            <input id="edit-expires" type="date" class="w-full px-3 py-2 rounded-[var(--radius-button)] bg-[var(--input-bg)] text-[var(--color-text)] text-sm border border-[var(--color-text)]" />
          </div>
          <div class="flex gap-2">
            <button id="edit-save" class="btn-primary flex-1 justify-center">save</button>
            <button id="edit-cancel" class="px-4 py-2 rounded-[var(--radius-button)] text-sm border border-[var(--color-text)] text-[var(--color-text)] hover:bg-[var(--glass-bg)] transition-all cursor-pointer bg-transparent">cancel</button>
          </div>
          <p id="edit-error" class="text-xs text-[var(--color-text)] hidden"></p>
        </div>
      </div>
    </div>

    <div id="admin-error" class="glass p-6 text-center hidden">
      <p class="text-sm text-[var(--color-text)]">access denied</p>
      <p class="text-xs text-[var(--color-text-secondary)] mt-2">you don't have permission to view this page</p>
      <a href="/account" class="inline-block mt-4 text-xs text-[var(--color-text)] underline">back to account</a>
    </div>
  </main>
  <script>
    var API_BASE = "https://zen-zakura-api.zen-zakura.workers.dev";
    var token = localStorage.getItem("zz_token");
    if (!token) { window.location.href = "/account"; }

    var currentPage = 1, currentSearch = "";

    function showError() { document.getElementById("admin-loading").classList.add("hidden"); document.getElementById("admin-content").classList.add("hidden"); document.getElementById("admin-error").classList.remove("hidden"); }

    function loadUsers(page, search) {
      var url = API_BASE + "/admin/users?page=" + (page || 1);
      if (search) url += "&search=" + encodeURIComponent(search);
      fetch(url, { headers: { Authorization: "Bearer " + token } }).then(function(r) { return r.json(); }).then(function(data) {
        var tbody = document.getElementById("users-body");
        var empty = document.getElementById("users-empty");
        var pagination = document.getElementById("users-pagination");
        tbody.innerHTML = "";

        if (!data.users || data.users.length === 0) {
          empty.classList.remove("hidden");
          pagination.innerHTML = "";
          return;
        }
        empty.classList.add("hidden");

        data.users.forEach(function(u) {
          var tr = document.createElement("tr");
          tr.className = "border-b border-[var(--color-text)] border-opacity-10";
          var expires = u.sub_expires ? new Date(u.sub_expires).toLocaleDateString() : "—";
          tr.innerHTML = '<td class="py-2 pr-2 text-[var(--color-text)]">' + u.id + '</td>' +
            '<td class="py-2 pr-2 text-[var(--color-text)]">' + escapeHtml(u.email) + '</td>' +
            '<td class="py-2 pr-2 text-[var(--color-text-secondary)]">' + (u.username ? '@' + escapeHtml(u.username) : '—') + '</td>' +
            '<td class="py-2 pr-2"><span class="px-2 py-0.5 rounded-full text-[10px] border border-[var(--color-text)] text-[var(--color-text)]">' + u.sub_status + '</span></td>' +
            '<td class="py-2 pr-2 text-[var(--color-text-secondary)] text-xs">' + expires + '</td>' +
            '<td class="py-2"><button class="text-xs text-[var(--color-text)] hover:opacity-70 cursor-pointer bg-transparent border-none" onclick="editUser(' + u.id + ',\'' + u.sub_status + '\',\'' + (u.sub_expires || '') + '\')">edit</button></td>';
          tbody.appendChild(tr);
        });

        var totalPages = Math.ceil(data.total / data.limit);
        pagination.innerHTML = "";
        for (var i = 1; i <= totalPages && i <= 10; i++) {
          var btn = document.createElement("button");
          btn.textContent = i;
          btn.className = "px-2 py-1 rounded text-xs border border-[var(--color-text)] text-[var(--color-text)] hover:bg-[var(--glass-bg)] transition-all cursor-pointer bg-transparent" + (i === data.page ? " bg-[var(--color-text)] text-white" : "");
          btn.onclick = function(p) { return function() { loadUsers(p, currentSearch); }; }(i);
          pagination.appendChild(btn);
        }
      }).catch(function() {});
    }

    function escapeHtml(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

    var editUserId = null;
    function editUser(id, status, expires) {
      editUserId = id;
      document.getElementById("edit-id").textContent = id;
      document.getElementById("edit-status").value = status;
      document.getElementById("edit-expires").value = expires ? expires.slice(0,10) : "";
      document.getElementById("edit-modal").classList.remove("hidden");
      document.getElementById("edit-error").classList.add("hidden");
    }

    document.getElementById("edit-cancel").addEventListener("click", function() {
      document.getElementById("edit-modal").classList.add("hidden");
    });

    document.getElementById("edit-save").addEventListener("click", function() {
      var status = document.getElementById("edit-status").value;
      var expires = document.getElementById("edit-expires").value;
      var body = JSON.stringify({ sub_status: status, sub_expires: expires || null });
      fetch(API_BASE + "/admin/users/" + editUserId + "/update", {
        method: "PATCH",
        headers: { "Content-Type": "application/json", Authorization: "Bearer " + token },
        body: body,
      }).then(function(r) {
        if (r.ok) {
          document.getElementById("edit-modal").classList.add("hidden");
          loadUsers(currentPage, currentSearch);
        } else {
          return r.json().then(function(d) { document.getElementById("edit-error").textContent = d.error || "error"; document.getElementById("edit-error").classList.remove("hidden"); });
        }
      }).catch(function() {});
    });

    document.getElementById("search-btn").addEventListener("click", function() {
      currentSearch = document.getElementById("search-input").value.trim();
      currentPage = 1;
      loadUsers(currentPage, currentSearch);
    });

    document.getElementById("search-input").addEventListener("keydown", function(e) {
      if (e.key === "Enter") document.getElementById("search-btn").click();
    });

    // Auth check
    fetch(API_BASE + "/verify", { headers: { Authorization: "Bearer " + token } }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.sub_status !== "dev") { showError(); return; }
      document.getElementById("admin-loading").classList.add("hidden");
      document.getElementById("admin-content").classList.remove("hidden");
      loadUsers(1, "");
    }).catch(function() { showError(); });
  </script>
</BaseLayout>
